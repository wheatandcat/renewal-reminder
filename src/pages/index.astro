---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <h1>精神障害者手帳 更新リマインダー</h1>
    <p class="intro">
      こんにちは！<br />
      あなたの障害者手帳更新をサポートします。
    </p>
    <p class="note">
      このwebサービスは現在開発中のベータ版です。<br />
      実際に必要な書類など間違いがないか、必ずご確認ください。
    </p>
    <p class="caption">※東京都の基準で運用しています</p>
    <img src="/images/welcome-animals.png" alt="" width="359" height="282" />

    <section id="ios-home-note" class="hidden ios-note">
      <p>
        iOSでPush通知を受け取るには、ホーム画面に追加してご利用ください。
      </p>
    </section>

    <button type="button" class="btn-outline hidden" id="install-btn">
      ホーム画面に追加
    </button>
    <section id="install-guide" class="hidden ios-note">
      <p>
        Safariの共有ボタン →
        「ホーム画面に追加」を選択後、ホーム画面のアイコンから開き直してください。
      </p>
    </section>

    <a class="btn-outline" id="start-btn" href="/setup">はじめる</a>
  </main>
</Layout>

<style>
  .hidden {
    display: none !important;
  }
  main {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }
  h1 {
    margin: 0;
    color: var(--color-white);
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    font-weight: 700;
    word-break: keep-all;
  }
  .intro {
    margin: 1rem 0 0;
    font-size: 1.1rem;
  }
  .note {
    margin: 0.5rem 0 0;
    font-size: 1rem;
  }
  .caption {
    margin: 0;
    font-size: 0.85rem;
  }
  img {
    max-width: 100%;
    height: auto;
  }
  .btn-outline {
    margin-top: 1rem;
    min-width: 190px;
  }
  .btn-outline:disabled,
  .btn-outline[aria-disabled="true"] {
    opacity: 0.5;
    pointer-events: none;
  }
  .ios-note {
    width: 100%;
    max-width: 400px;
    background: var(--color-white);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
  }
  .ios-note p {
    margin: 0;
  }
</style>

<script>
  import { loadSettings } from "../lib/store";
  import { isAndroid, isIos, isStandalone } from "../lib/platform";

  const ios = isIos();
  const standalone = isStandalone();

  const startBtn = document.getElementById("start-btn") as HTMLAnchorElement;
  const iosHomeNoteEl = document.getElementById("ios-home-note")!;
  const installBtn = document.getElementById(
    "install-btn",
  ) as HTMLButtonElement;
  const installGuideEl = document.getElementById("install-guide")!;

  // iOSはホーム画面に追加(standalone)しないとWeb Pushを受け取れない
  const iosNeedsHomeScreen = ios && !standalone;
  if (iosNeedsHomeScreen) {
    iosHomeNoteEl.classList.remove("hidden");
    startBtn.setAttribute("aria-disabled", "true");
  }

  startBtn.addEventListener("click", (e) => {
    if (iosNeedsHomeScreen) {
      e.preventDefault();
      return;
    }
    if (loadSettings()) {
      e.preventDefault();
      location.href = "/checklist";
    }
  });

  // ホーム画面追加ボタン: Android/iOSのブラウザ表示時のみ表示
  let deferredInstallPrompt: any = null;
  if ((isAndroid() || ios) && !standalone) {
    installBtn.classList.remove("hidden");
  }

  window.addEventListener("beforeinstallprompt", (e) => {
    e.preventDefault();
    deferredInstallPrompt = e;
  });

  installBtn.addEventListener("click", async () => {
    if (deferredInstallPrompt) {
      deferredInstallPrompt.prompt();
      await deferredInstallPrompt.userChoice;
      deferredInstallPrompt = null;
      return;
    }
    if (ios) {
      installGuideEl.classList.remove("hidden");
    }
  });
</script>
