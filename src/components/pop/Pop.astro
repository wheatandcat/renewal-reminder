<details class="pop">
  <summary>？</summary>
  <div class="pop-card">
    <slot />
  </div>
</details>

<script>
  document.addEventListener("click", (e) => {
    for (const pop of document.querySelectorAll<HTMLDetailsElement>(
      "details.pop[open]",
    )) {
      if (!pop.contains(e.target as Node)) {
        pop.open = false;
      }
    }
  });
</script>

<style>
  /* ？ポップオーバー */
  .pop {
    position: relative;
    margin-bottom: 0.9rem;
  }
  .pop summary {
    list-style: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .pop-card {
    position: absolute;
    z-index: 10;
    left: 30px;
    top: -10px;
    width: min(276px, 70vw);
    background: var(--color-white);
    border-radius: 3px;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
  }
  .pop-card :global(ul) {
    list-style: none;
    margin: 0 0 0.75rem;
    padding: 0;
  }
  .pop-card :global(.pop-text) {
    display: inline-block;
